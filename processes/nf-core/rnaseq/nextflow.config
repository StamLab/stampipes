// nf-core/rnaseq configuration for Prime-seq data with pre-extracted UMIs
// Using existing STAR index and local references

params {
    // Basic pipeline settings
    outdir = './results'
    
    // Input data
    input = './data/samplesheet.csv'
    
    // Reference files - GENCODE v44 with TALE modifications
    fasta = '/net/seq/data2/projects/megamap2024/reference/resources_filtered/GENOME_TALE_REF/GRCh38_GENCODE_GIAB-chrY-plusDecoys.primary_assembly.genome_TALE_chr.fa'
    //gtf = '/net/seq/data2/projects/megamap2024/reference/resources_filtered/GENCODE_TALE/gencode.v44.primary_assembly.basic.annotation_TALE_genes.gtf'
    gtf = '/net/seq/data2/projects/rsandstrom/altseq-rnaseq/GENCODE_FIX/fix.gencode.v44.primary_assembly.basic.annotation_TALE_genes.gtf'
    
    // Use your existing STAR 2.7.11b index
    star_index = '/net/seq/data2/projects/megamap2024/reference/star_2.7.11b_06012025_genome_megamap/'
    
    // GENCODE-specific settings
    gencode = true
    
    // Alignment settings
    aligner = 'star_salmon'  // STAR for alignment + Salmon for quantification
    
    // UMI processing - UMIs already in read headers from demux
    with_umi = true
    skip_umi_extract = true  // CRITICAL: UMIs already extracted during demux
    umi_discard_read = 1     // UMIs are in R1 headers
    umitools_dedup_stats = true
    
    // BigWig generation - DO NOT SKIP
    skip_bigwig = false  // Ensure BigWigs are generated (this is default)
    
    // Skip index generation since we're using pre-built
    save_reference = false
    
    // QC and trimming
    skip_fastqc = false
    skip_trimming = false
    
    // Resource efficiency
    save_trimmed = false
    save_unaligned = false
    save_align_intermeds = false
    
    // Pipeline options
    email = null  // Add your email for completion notifications if desired

    save_umi_intermeds = true  // Publish deduplicated BAMs
}

// Singularity/Apptainer configuration
apptainer {
    enabled = true
    autoMounts = true
    cacheDir = "${launchDir}/apptainer_cache"
    pullTimeout = '60m'
}

// SLURM executor configuration
executor {
    name = 'slurm'
    queueSize = 20
}

// Process-specific resource allocation
process {
    executor = 'slurm'
    
    // Default queue
    queue = 'hpcy-test,hpcz-test'
    
    // Error handling
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Process labels for resource allocation
    withLabel: process_single {
        cpus = 1
        memory = 8.GB
        time = 4.h
    }
    
    withLabel: process_low {
        cpus = 4
        memory = 16.GB
        time = 6.h
    }
    
    withLabel: process_medium {
        cpus = 8
        memory = 32.GB
        time = 8.h
    }
    
    withLabel: process_high {
        cpus = 16
        memory = 64.GB
        time = 12.h
    }
    
    withLabel: process_long {
        time = 24.h
    }
    
    // STAR alignment needs substantial memory
    withName: 'NFCORE_RNASEQ:RNASEQ:ALIGN_STAR:STAR_ALIGN' {
        cpus = 12
        memory = 64.GB
        time = 8.h
    }
   
    // Fix for samtools sort naming conflict in UMI dedup workflow
    withName: 'NFCORE_RNASEQ:RNASEQ:BAM_DEDUP_UMI_STAR:SAMTOOLS_SORT' {
        ext.prefix = { "${meta.id}.sorted" }
        cpus = 4
        memory = 16.GB
        time = 4.h
    }
 
    // UMI deduplication - can be memory intensive
    withName: 'NFCORE_RNASEQ:RNASEQ:BAM_DEDUP_STATS_SAMTOOLS_UMITOOLS:UMITOOLS_DEDUP' {
        cpus = 8
        memory = 32.GB
        time = 12.h
    }
    
    // BigWig generation
    withName: 'NFCORE_RNASEQ:RNASEQ:.*:BEDTOOLS_GENOMECOV' {
        cpus = 2
        memory = 8.GB
        time = 4.h
    }
    
    // Salmon quantification
    withName: 'NFCORE_RNASEQ:RNASEQ:QUANTIFY_STAR_SALMON:SALMON_QUANT' {
        cpus = 8
        memory = 16.GB
        time = 4.h
    }

    // DUPRADAR - limit time to avoid exceeding partition limits
    withName: 'NFCORE_RNASEQ:RNASEQ:DUPRADAR' {
        cpus = 4
        memory = 16.GB
        time = 6.h
    }
}

// Report settings
report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
}

timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
}

dag {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/pipeline_dag.html"
}
